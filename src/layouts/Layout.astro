---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title = "WebSolution | Houston's Trusted Web Design, SEO & AI Agency", description = "Get Found on Google, AI Search & Beyond. Complete Digital Growth Solutions for Houston Businesses" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    <link rel="shortcut icon" href="/favicon.png">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CDNs -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Page-specific head content -->
    <slot name="head" />
</head>
<body class="antialiased bg-slate-950">
    <div class="bg-slate-950 text-slate-200 font-sans min-h-screen selection:bg-brand-500 selection:text-white" style="font-family: 'Inter', sans-serif;">
        <Navbar />
        <slot />
        <Footer />
    </div>
</body>
</html>
