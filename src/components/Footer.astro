---
---

<footer class="bg-slate-950 pt-16 border-t border-white/5 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-gradient-to-tl from-brand-500/10 to-brand-600/5 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="container mx-auto px-6 relative z-10">
        <!-- Top CTA Banner -->
        <div class="bg-slate-900 border border-white/5 rounded-3xl p-8 md:p-12 mb-16 relative overflow-hidden flex flex-col lg:flex-row justify-between items-center gap-8">
            <div class="absolute top-0 right-0 w-64 h-64 bg-brand-500/5 blur-2xl rounded-full pointer-events-none"></div>
            
            <div class="lg:w-2/3">
                <div class="inline-block px-3 py-1 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-xs font-semibold mb-4">
                    Get in Touch
                </div>
                <h3 class="text-3xl font-bold text-white mb-4">Ready to Grow Your Business Online?</h3>
                <p class="text-slate-300 text-sm leading-relaxed mb-4">
                    Whether you need a new website, better SEO rankings, AI search visibility, Google Maps optimization, website maintenance, or PPC management, Websolution provides the expertise and support needed to help your business succeed online.
                </p>
                <p class="text-slate-400 text-sm leading-relaxed">
                    Contact our Houston-based digital marketing team today to discuss a customized growth strategy designed specifically for your business goals.
                </p>
            </div>

            <div class="lg:w-1/3 flex flex-col items-center lg:items-end justify-center w-full shrink-0">
                <a href="tel:+18322667209" class="w-full lg:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 rounded-lg text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-1 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.8)] border border-brand-400/30 text-center">
                    📞 Start Growing Today
                </a>
                <div class="mt-4 text-xs text-slate-500 flex flex-col items-center lg:items-end">
                    <span>websolutiontx@gmail.com</span>
                    <span class="mt-1">+1 (832) 266-7209</span>
                </div>
            </div>
        </div>
        <div class="grid md:grid-cols-4 gap-12 pb-12 border-b border-white/5">
            <!-- Brand -->
            <div class="md:col-span-2">
                <a href="/" class="flex items-center mb-6">
                    <img src="/images/websolution-logo.png" alt="WebSolution Logo" class="h-10 w-auto object-contain">
                </a>
                <p class="text-slate-400 text-sm leading-relaxed max-w-xs mb-6">
                    A full-service digital agency helping forward-thinking brands design, build, and grow their online presence.
                </p>
                <div class="flex gap-3">
                    <a href="/contact" aria-label="X/Twitter" class="w-9 h-9 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:text-white hover:bg-brand-500 transition-all">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href="/contact" aria-label="LinkedIn" class="w-9 h-9 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:text-white hover:bg-brand-500 transition-all">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z"/></svg>
                    </a>
                    <a href="/contact" aria-label="Instagram" class="w-9 h-9 rounded-lg bg-slate-800 flex items-center justify-center text-slate-400 hover:text-white hover:bg-brand-500 transition-all">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    </a>
                </div>
            </div>

            <!-- Links -->
            <div>
                <h4 class="text-white font-semibold mb-5 text-sm tracking-wide uppercase">Company</h4>
                <ul class="space-y-3 text-sm text-slate-400">
                    <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
                    <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
                    <li><a href="/our-work" class="hover:text-white transition-colors">Our Work</a></li>
                    <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
                    <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
                </ul>
            </div>

            <!-- Services -->
            <div>
                <h4 class="text-white font-semibold mb-5 text-sm tracking-wide uppercase">Services</h4>
                <ul class="space-y-3 text-sm text-slate-400">
                    <li><a href="/services" class="hover:text-white transition-colors">Web Development</a></li>
                    <li><a href="/services" class="hover:text-white transition-colors">App Development</a></li>
                    <li><a href="/services" class="hover:text-white transition-colors">UI/UX Design</a></li>
                    <li><a href="/services" class="hover:text-white transition-colors">Digital Marketing</a></li>
                    <li><a href="/services" class="hover:text-white transition-colors">SEO Optimization</a></li>
                    <li><a href="/services" class="hover:text-white transition-colors">Brand Strategy</a></li>
                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-slate-500">
            <p>© 2026 WebSolution. All rights reserved.</p>
            <div class="flex gap-6">
                <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
                <a href="/terms-of-service" class="hover:text-white transition-colors">Terms of Service</a>
            </div>
        </div>
    </div>
</footer>
