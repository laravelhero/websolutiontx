---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | Web Solution Agency" description="Learn about the passionate team behind Web Solution Agency — designers, developers, and strategists dedicated to building impactful digital experiences.">
    <!-- Hero -->
    <section x-data="{ loaded: false }" x-init="setTimeout(() => loaded = true, 100)"
             class="relative min-h-[60vh] flex items-end pt-32 pb-24 overflow-hidden bg-black">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-r from-black via-black/70 to-transparent z-10"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-black/40 to-transparent z-10"></div>
            <img src="/images/team-culture.png" alt="Our creative studio" class="w-full h-full object-cover object-center opacity-60">
        </div>
        <div class="absolute top-1/2 right-16 -translate-y-1/2 w-[500px] h-[500px] bg-brand-600/20 blur-[150px] rounded-full pointer-events-none hidden lg:block"></div>
        <div class="container mx-auto px-6 relative z-10"
             x-bind:class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-10'"
             style="transition: all 1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;">
            <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6">
                About Us
            </div>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] mb-6 tracking-tight max-w-3xl">
                A Team Built for <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">Digital Excellence.</span>
            </h1>
            <p class="text-xl text-slate-300 max-w-xl leading-relaxed">
                We're not just an agency — we're your dedicated digital growth partner, obsessed with craft, results, and long-term relationships.
            </p>
        </div>
    </section>

    <!-- Our Story Section (Synced with Homepage About Section) -->
    <section class="py-24 bg-slate-900/50">
        <div class="container mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-16 items-stretch">
                <div class="relative flex flex-col justify-stretch">
                    <div class="h-full min-h-[400px] lg:min-h-[600px] rounded-2xl overflow-hidden shadow-2xl relative">
                        <img src="/images/about-team-tall.png" alt="Our team collaborating on custom web design and SEO" class="w-full h-full object-cover object-center">
                    </div>
                    <!-- Decorative element -->
                    <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-gradient-to-br from-brand-500 to-brand-600 rounded-full blur-2xl opacity-40 z-[-1]"></div>
                </div>
                
                <div>
                    <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6">
                        Our Story
                    </div>
                    <h2 class="text-4xl font-bold text-white mb-6">Complete Online Growth Solutions for Houston's Businesses</h2>
                    <p class="text-slate-400 mb-4 leading-relaxed text-lg">
                        Your website should do more than just exist online—it should generate leads, attract customers, rank in Google, appear in AI search results, and help your business grow consistently.
                    </p>
                    <p class="text-slate-400 mb-4 leading-relaxed">
                        At Websolution, we help businesses throughout Houston and across Texas build a stronger digital presence through professional website design, search engine optimization (SEO), AI Search Optimization (AISO), Google Business Profile management, website maintenance, and PPC advertising.
                    </p>
                    <p class="text-slate-400 mb-8 leading-relaxed">
                        Whether you are a startup, local business, medical practice, law firm, contractor, retailer, or growing corporation, our team develops customized digital marketing strategies designed to increase visibility, generate qualified leads, and maximize return on investment.
                    </p>
                    
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 mb-10">
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">150+</div>
                            <div class="text-sm text-slate-500">Projects Delivered</div>
                        </div>
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">100+</div>
                            <div class="text-sm text-slate-500">Happy Clients</div>
                        </div>
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">10+</div>
                            <div class="text-sm text-slate-500">Industry Awards</div>
                        </div>
                    </div>

                    <a href="tel:+18322667209" class="inline-flex items-center gap-3 px-8 py-4 rounded-lg text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-1 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.8)] border border-brand-400/30">
                        🚀 Boost Your Google Rankings &amp; AI Visibility
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values -->
    <section class="py-24">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-4">
                    Our Values
                </div>
                <h2 class="text-4xl md:text-5xl font-bold text-white">What Drives Us Every Day</h2>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Value 1 -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 text-brand-400 group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-3">Quality First</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">We never ship work we're not proud of. Every pixel, every line of code meets our internal bar for excellence.</p>
                </div>
                <!-- Value 2 -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 text-brand-400 group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-3">Client-Centric</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Your goals are our goals. We invest deeply in understanding your business before we write a single line of code.</p>
                </div>
                <!-- Value 3 -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 text-brand-400 group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-3">Move Fast</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">We combine agile thinking with premium craft — moving fast without sacrificing the details that matter.</p>
                </div>
                <!-- Value 4 -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-1">
                    <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center mb-6 text-brand-400 group-hover:scale-110 transition-transform">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-3">Always Innovating</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">We stay ahead of the curve — constantly exploring new tools, technologies, and creative approaches.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Texas Businesses Choose Websolution Section -->
    <section class="py-24 bg-slate-900/40 border-t border-b border-white/5 relative overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[300px] bg-brand-600/5 blur-[130px] rounded-full pointer-events-none"></div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-3xl mx-auto text-center mb-16">
                <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6">
                    Why Choose Us
                </div>
                <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Why Texas Businesses Choose Websolution</h2>
                <p class="text-slate-400 text-lg leading-relaxed max-w-2xl mx-auto">
                    Partnering with us means gaining a dedicated, results-driven digital growth partner. We build custom campaigns designed to unlock real, measurable market dominance.
                </p>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Houston-Based Team -->
                <div class="group p-8 rounded-2xl bg-slate-950 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-2 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <h3 class="text-xl font-bold text-white mb-3">Houston-Based Team</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">We live and work right here. We fully understand the Texas market dynamics, regional audience demands, and local competition.</p>
                </div>
                <!-- Complete Marketing Solutions -->
                <div class="group p-8 rounded-2xl bg-slate-950 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-2 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <h3 class="text-xl font-bold text-white mb-3">Complete Marketing Solutions</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">One agency. One unified growth strategy. One expert point of contact to handle your design, development, SEO, and paid acquisition.</p>
                </div>
                <!-- AI Search Experts -->
                <div class="group p-8 rounded-2xl bg-slate-950 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-2 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <h3 class="text-xl font-bold text-white mb-3">AI Search Experts</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">We don't just optimize for standard search engines. We prepare businesses for the future of AI search answers and chat interfaces.</p>
                </div>
                <!-- Transparent Reporting -->
                <div class="group p-8 rounded-2xl bg-slate-950 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-2 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-teal-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <h3 class="text-xl font-bold text-white mb-3">Transparent Reporting</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">No smoke and mirrors. You get clear, easy-to-understand reporting dashboards showcasing measurable business metrics and conversion performance.</p>
                </div>
                <!-- Custom Strategies -->
                <div class="group p-8 rounded-2xl bg-slate-950 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-2 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-red-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <h3 class="text-xl font-bold text-white mb-3">Custom Strategies</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">No standard cookie-cutter templates. We formulate highly personalized, unique campaigns customized exactly to your business objectives.</p>
                </div>
                <!-- Fast Support -->
                <div class="group p-8 rounded-2xl bg-slate-950 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-2 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-green-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <h3 class="text-xl font-bold text-white mb-3">Fast Support</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Fast, direct, and responsive communication combined with reliable technical assistance whenever your systems require attention.</p>
                </div>
            </div>
        </div>
    </section>

</Layout>
