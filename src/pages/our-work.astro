---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Work | Web Solution Agency" description="Browse our portfolio of web design, app development, and digital marketing projects delivered for clients worldwide.">
    <!-- Hero -->
    <section x-data="{ loaded: false }" x-init="setTimeout(() => loaded = true, 100)"
             class="relative min-h-[60vh] flex items-end pt-32 pb-24 overflow-hidden bg-black">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-r from-black via-black/70 to-transparent z-10"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-black/30 to-transparent z-10"></div>
            <img src="/images/our-work-hero.png" alt="Our portfolio" class="w-full h-full object-cover opacity-60">
        </div>
        <div class="container mx-auto px-6 relative z-10"
             x-bind:class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-10'"
             style="transition: all 1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;">
            <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6">
                Our Work
            </div>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] mb-6 tracking-tight max-w-3xl">
                Projects That <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">Speak for Themselves.</span>
            </h1>
            <p class="text-xl text-slate-300 max-w-xl leading-relaxed">
                Explore a curated selection of projects where great design meets powerful engineering.
            </p>
        </div>
    </section>

    <!-- Portfolio Filter + Grid -->
    <section class="py-24" x-data="{ active: 'All' }">
        <div class="container mx-auto px-6">

            <!-- Filter Tabs -->
            <div class="flex flex-wrap justify-center gap-3 mb-16">
                <button @click="active = 'All'"
                        :class="active === 'All' ? 'bg-gradient-to-r from-brand-500 to-brand-600 text-white border-transparent' : 'bg-slate-800 text-slate-300 hover:bg-slate-700 border border-white/5'"
                        class="px-6 py-2 rounded-full text-sm font-medium transition-all duration-200">
                    All
                </button>
                <button @click="active = 'UI/UX'"
                        :class="active === 'UI/UX' ? 'bg-gradient-to-r from-brand-500 to-brand-600 text-white border-transparent' : 'bg-slate-800 text-slate-300 hover:bg-slate-700 border border-white/5'"
                        class="px-6 py-2 rounded-full text-sm font-medium transition-all duration-200">
                    UI/UX
                </button>
                <button @click="active = 'Web Dev'"
                        :class="active === 'Web Dev' ? 'bg-gradient-to-r from-brand-500 to-brand-600 text-white border-transparent' : 'bg-slate-800 text-slate-300 hover:bg-slate-700 border border-white/5'"
                        class="px-6 py-2 rounded-full text-sm font-medium transition-all duration-200">
                    Web Dev
                </button>
                <button @click="active = 'App'"
                        :class="active === 'App' ? 'bg-gradient-to-r from-brand-500 to-brand-600 text-white border-transparent' : 'bg-slate-800 text-slate-300 hover:bg-slate-700 border border-white/5'"
                        class="px-6 py-2 rounded-full text-sm font-medium transition-all duration-200">
                    App
                </button>
                <button @click="active = 'Marketing'"
                        :class="active === 'Marketing' ? 'bg-gradient-to-r from-brand-500 to-brand-600 text-white border-transparent' : 'bg-slate-800 text-slate-300 hover:bg-slate-700 border border-white/5'"
                        class="px-6 py-2 rounded-full text-sm font-medium transition-all duration-200">
                    Marketing
                </button>
            </div>

            <!-- Projects Grid -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Project 1 -->
                <div x-show="active === 'All' || active === 'UI/UX' || active === 'Web Dev'" class="group rounded-2xl overflow-hidden bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/images/project-ecommerce.png" alt="E-Commerce Redesign" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-70"></div>
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 backdrop-blur-sm">
                            <div class="w-12 h-12 rounded-full bg-brand-500 text-white flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-xs text-slate-500 font-medium tracking-wide">AURA Fashion</span>
                            <div class="flex gap-1.5">
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">UI/UX</span>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">Web Dev</span>
                            </div>
                        </div>
                        <h3 class="text-lg font-bold text-white mb-2">E-Commerce Redesign</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Complete redesign of a luxury fashion e-commerce store resulting in 47% increase in conversion rate.</p>
                    </div>
                </div>

                <!-- Project 2 -->
                <div x-show="active === 'All' || active === 'App' || active === 'UI/UX'" class="group rounded-2xl overflow-hidden bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/images/project-fintech.png" alt="Fintech Dashboard" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-70"></div>
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 backdrop-blur-sm">
                            <div class="w-12 h-12 rounded-full bg-brand-500 text-white flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-xs text-slate-500 font-medium tracking-wide">Nexus Fintech</span>
                            <div class="flex gap-1.5">
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">App</span>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">UI/UX</span>
                            </div>
                        </div>
                        <h3 class="text-lg font-bold text-white mb-2">Fintech Dashboard</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Real-time financial analytics dashboard serving 10,000+ active portfolio managers.</p>
                    </div>
                </div>

                <!-- Project 3 -->
                <div x-show="active === 'All' || active === 'Web Dev' || active === 'Marketing'" class="group rounded-2xl overflow-hidden bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/images/project-saas.png" alt="SaaS Landing Page" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-70"></div>
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 backdrop-blur-sm">
                            <div class="w-12 h-12 rounded-full bg-brand-500 text-white flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-xs text-slate-500 font-medium tracking-wide">FlowState</span>
                            <div class="flex gap-1.5">
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">Web Dev</span>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">Marketing</span>
                            </div>
                        </div>
                        <h3 class="text-lg font-bold text-white mb-2">SaaS Landing Page</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">High-converting SaaS landing page with A/B tested copy that reduced bounce rate by 38%.</p>
                    </div>
                </div>

                <!-- Project 4 -->
                <div x-show="active === 'All' || active === 'Web Dev' || active === 'UI/UX'" class="group rounded-2xl overflow-hidden bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/images/project-ecommerce.png" alt="Healthcare Portal" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-70"></div>
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 backdrop-blur-sm">
                            <div class="w-12 h-12 rounded-full bg-brand-500 text-white flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-xs text-slate-500 font-medium tracking-wide">MediCore</span>
                            <div class="flex gap-1.5">
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">Web Dev</span>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">UI/UX</span>
                            </div>
                        </div>
                        <h3 class="text-lg font-bold text-white mb-2">Healthcare Portal</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">HIPAA-compliant patient portal with appointment booking and telemedicine integration.</p>
                    </div>
                </div>

                <!-- Project 5 -->
                <div x-show="active === 'All' || active === 'App'" class="group rounded-2xl overflow-hidden bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/images/project-fintech.png" alt="Real Estate App" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-70"></div>
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 backdrop-blur-sm">
                            <div class="w-12 h-12 rounded-full bg-brand-500 text-white flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-xs text-slate-500 font-medium tracking-wide">PropertyPro</span>
                            <div class="flex gap-1.5">
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">App</span>
                            </div>
                        </div>
                        <h3 class="text-lg font-bold text-white mb-2">Real Estate App</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Cross-platform property listing and management app with map-based search.</p>
                    </div>
                </div>

                <!-- Project 6 -->
                <div x-show="active === 'All' || active === 'UI/UX' || active === 'Marketing'" class="group rounded-2xl overflow-hidden bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/images/project-saas.png" alt="Brand Refresh" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-70"></div>
                        <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40 backdrop-blur-sm">
                            <div class="w-12 h-12 rounded-full bg-brand-500 text-white flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-xs text-slate-500 font-medium tracking-wide">Enovara Inc.</span>
                            <div class="flex gap-1.5">
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">UI/UX</span>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-800 text-slate-400">Marketing</span>
                            </div>
                        </div>
                        <h3 class="text-lg font-bold text-white mb-2">Brand Refresh</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Complete brand identity overhaul including visual guidelines, website, and digital campaigns.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Bar -->
    <section class="py-16 bg-slate-900 border-y border-white/5">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                <div>
                    <div class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600 mb-2">150+</div>
                    <div class="text-sm text-slate-500">Projects Delivered</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600 mb-2">100+</div>
                    <div class="text-sm text-slate-500">Happy Clients</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600 mb-2">10+</div>
                    <div class="text-sm text-slate-500">Industry Awards</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600 mb-2">98%</div>
                    <div class="text-sm text-slate-500">Client Retention</div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-24">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Your Project Could Be Next</h2>
            <p class="text-slate-400 text-lg mb-10 max-w-lg mx-auto">Every great project starts with a conversation. Let's talk about yours.</p>
            <a href="tel:+18322667209" class="inline-flex items-center justify-center px-10 py-4 rounded-lg text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-1 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.8)] border border-brand-400/30">
                Start Your Project Today
            </a>
        </div>
    </section>
</Layout>
