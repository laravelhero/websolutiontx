---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WebSolution | Houston's Trusted Web Design, SEO & AI Agency" description="Get Found on Google, AI Search & Beyond. Complete Digital Growth Solutions for Houston Businesses">
    <!-- Hero Section -->
    <section x-data="{ loaded: false, scrollY: 0 }" 
             @scroll.window="scrollY = window.pageYOffset"
             x-init="setTimeout(() => loaded = true, 100)" 
             class="relative min-h-[100vh] flex items-center pt-20 overflow-hidden bg-black">
        
        <!-- Background Image with Parallax -->
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-black/50 z-10"></div> <!-- subtle overlay for text readability -->
            <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-transparent z-10 pointer-events-none"></div> <!-- left gradient fade -->
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-black/50 to-transparent z-10 pointer-events-none"></div> <!-- bottom gradient fade -->
            <img src="/images/abstract-wave-bg.png" alt="Hero Background" 
                 class="w-full h-full object-cover object-center opacity-100 transition-all duration-[2000ms] ease-out"
                 :style="`transform: translateY(${scrollY * 0.3}px) scale(${loaded ? 1.05 : 1.1}); opacity: ${loaded ? 0.8 : 0};`">
        </div>

        <!-- Fluid Glow Element (Left) -->
        <div class="absolute top-1/4 left-0 -translate-x-1/4 w-[600px] h-[600px] bg-brand-600/30 blur-[150px] rounded-full mix-blend-screen pointer-events-none"
             x-bind:class="loaded ? 'opacity-100 translate-x-0' : 'opacity-0 -translate-x-20'"
             style="transition: all 1.5s ease-out 0.5s;"></div>

        <!-- Floating Orb Element (Top Right) -->
        <div class="absolute top-32 right-32 w-48 h-48 rounded-full border border-brand-500/20 bg-gradient-to-tr from-brand-600/30 to-brand-400/5 blur-[2px] shadow-[0_0_80px_rgba(219,107,39,0.2)] hidden lg:block"
             x-bind:class="loaded ? 'opacity-100 translate-y-0 scale-100' : 'opacity-0 translate-y-10 scale-90'"
             :style="`transition: all 1.5s cubic-bezier(0.4, 0, 0.2, 1) 0.6s; transform: translateY(${scrollY * -0.2}px);`">
            <!-- Abstract glowing inner element to mimic the orb -->
            <div class="absolute inset-0 rounded-full border-[1px] border-dashed border-brand-400/40 animate-[spin_12s_linear_infinite]"></div>
            <div class="absolute inset-4 rounded-full border-[2px] border-dotted border-white/20 animate-[spin_20s_linear_infinite_reverse]"></div>
            <div class="absolute inset-1/4 bg-brand-500/20 rounded-full blur-xl animate-pulse"></div>
        </div>

        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-3xl"
                 x-bind:class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-10'"
                 style="transition: all 1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;">
                <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.15] md:leading-[1.1] mb-6 tracking-tight">
                    Houston's Trusted <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">Website Design,</span><br>
                    SEO, AI Optimization &amp; Digital Marketing Agency
                </h1>
                <p class="text-lg md:text-xl text-slate-300 mb-4 max-w-xl leading-relaxed"
                   x-bind:class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-10'"
                   style="transition: all 1s cubic-bezier(0.4, 0, 0.2, 1) 0.4s;">
                    Complete Online Growth Solutions for Texas Businesses designed to help your website attract more customers, generate qualified leads, rank higher in Google, appear in AI-powered search results, and fuel long-term business growth.
                </p>
                <p class="text-base text-slate-400 mb-10 max-w-xl leading-relaxed"
                   x-bind:class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-10'"
                   style="transition: all 1s cubic-bezier(0.4, 0, 0.2, 1) 0.5s;">
                    Ready to Grow Your Business? Call <a href="tel:+18322667209" class="text-brand-400 font-semibold hover:text-brand-300 transition-colors">(832) 266-7209</a> for a Free Consultation.
                </p>
                <div x-bind:class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-10'"
                     style="transition: all 1s cubic-bezier(0.4, 0, 0.2, 1) 0.6s;">
                    <a href="tel:+18322667209" class="inline-flex items-center justify-center px-8 py-4 rounded-lg text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-1 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.8)] border border-brand-400/30">
                        Start Growing My Business Today
                    </a>
                </div>
            </div>
        </div>

    </section>

    <!-- About Section -->
    <section class="py-24 bg-slate-900/50">
        <div class="container mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-16 items-stretch">
                <div class="relative flex flex-col justify-stretch">
                    <div class="h-full min-h-[400px] lg:min-h-[600px] rounded-2xl overflow-hidden shadow-2xl relative">
                        <img src="/images/about-team-tall.png" alt="Our team collaborating on custom web design and SEO" class="w-full h-full object-cover object-center">
                    </div>
                    <!-- Decorative element -->
                    <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-gradient-to-br from-brand-500 to-brand-600 rounded-full blur-2xl opacity-40 z-[-1]"></div>
                </div>
                
                <div>
                    <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6">
                        About Agency
                    </div>
                    <h2 class="text-4xl font-bold text-white mb-6">Complete Online Growth Solutions for Houston's Businesses</h2>
                    <p class="text-slate-400 mb-4 leading-relaxed text-lg">
                        Your website should do more than just exist online—it should generate leads, attract customers, rank in Google, appear in AI search results, and help your business grow consistently.
                    </p>
                    <p class="text-slate-400 mb-4 leading-relaxed">
                        At Websolution, we help businesses throughout Houston and across Texas build a stronger digital presence through professional website design, search engine optimization (SEO), AI Search Optimization (AISO), Google Business Profile management, website maintenance, and PPC advertising.
                    </p>
                    <p class="text-slate-400 mb-8 leading-relaxed">
                        Whether you are a startup, local business, medical practice, law firm, contractor, retailer, or growing corporation, our team develops customized digital marketing strategies designed to increase visibility, generate qualified leads, and maximize return on investment.
                    </p>
                    
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 mb-10">
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">150+</div>
                            <div class="text-sm text-slate-500">Projects Delivered</div>
                        </div>
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">100+</div>
                            <div class="text-sm text-slate-500">Happy Clients</div>
                        </div>
                        <div>
                            <div class="text-3xl font-bold text-white mb-1">10+</div>
                            <div class="text-sm text-slate-500">Industry Awards</div>
                        </div>
                    </div>

                    <a href="tel:+18322667209" class="inline-flex items-center gap-3 px-8 py-4 rounded-lg text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-1 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.8)] border border-brand-400/30">
                        🚀 Boost Your Google Rankings &amp; AI Visibility
