                        <div class="flex flex-wrap gap-2">
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Healthcare Practices</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Law Firms</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Construction Companies</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Restaurants</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Local Service Businesses</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Home Improvement</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Retail Stores</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Franchise Businesses</span>
                            <span class="text-xs px-3 py-1.5 rounded-lg bg-slate-900 border border-white/5 text-slate-300">Professional Services</span>
