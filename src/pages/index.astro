    <!-- Conversion Web Design Section -->
    <section class="py-24 bg-slate-950 border-t border-b border-white/5 relative overflow-hidden">
        <!-- Background Glow -->
        <div class="absolute top-1/2 right-0 translate-x-1/4 -translate-y-1/2 w-[600px] h-[600px] bg-brand-600/10 blur-[150px] rounded-full mix-blend-screen pointer-events-none"></div>

        <div class="container mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-16 items-stretch">
                <!-- Text Column -->
                <div class="flex flex-col justify-center">
                    <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6 self-start">
                        Conversion Optimization
                    </div>
                    <h2 class="text-4xl font-bold text-white mb-6">Professional Website Design That Converts Visitors Into Customers</h2>
                    
                    <p class="text-slate-300 text-lg mb-4 leading-relaxed">
                        Your website is often the first impression potential customers have of your business. A slow, outdated, or poorly designed website can cost you leads every day.
                    </p>
                    
                    <p class="text-slate-400 mb-8 leading-relaxed">
                        Our Houston-based website design team creates modern, mobile-friendly websites that are built to:
                    </p>

                    <!-- Key Benefits Grid -->
                    <div class="grid sm:grid-cols-2 gap-4 mb-10">
