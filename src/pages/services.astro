---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services | Web Solution Agency" description="Explore our full range of digital services — from web development and mobile apps to SEO, digital marketing, and brand strategy.">
    <!-- Hero -->
    <section x-data="{ loaded: false }" x-init="setTimeout(() => loaded = true, 100)"
             class="relative min-h-[60vh] flex items-end pt-32 pb-24 overflow-hidden bg-black">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-r from-black via-black/60 to-transparent z-10"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-black/30 to-transparent z-10"></div>
            <img src="/images/abstract-wave-bg.png" alt="Services background" class="w-full h-full object-cover object-center opacity-50">
        </div>
        <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-500/10 blur-[200px] rounded-full pointer-events-none"></div>
        <div class="container mx-auto px-6 relative z-10"
             x-bind:class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-10'"
             style="transition: all 1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;">
            <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6">
                Our Services
            </div>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] mb-6 tracking-tight max-w-3xl">
                All the Digital Services <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">Your Business Needs.</span>
            </h1>
            <p class="text-xl text-slate-300 max-w-xl leading-relaxed">
                From concept to launch and beyond — we cover every touchpoint of your digital journey with expertise and care.
            </p>
        </div>
    </section>

    <!-- Services Grid -->
    <section class="py-24">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-2 gap-8">
                <!-- 1. Web Development & Design -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <div class="flex items-start gap-6 mb-6">
                            <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center text-brand-400 shrink-0 group-hover:scale-110 transition-transform">
                                🩺
                            </div>
                            <div>
                                <span class="text-xs font-bold text-brand-500/60 tracking-widest uppercase">01</span>
                                <h3 class="text-xl font-bold text-white mt-1">Web Development &amp; Design</h3>
                            </div>
                        </div>
                        <p class="text-slate-400 mb-6 leading-relaxed">We build high-converting, fast, and secure websites that work flawlessly across all devices. Designed from day one with SEO and user experience in mind to transform visitors into customers.</p>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Fast load times &amp; speed optimization</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Mobile-friendly &amp; responsive interfaces</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Conversion-centric wireframes &amp; structures</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Custom CMS &amp; E-commerce integrations</li>
                        </ul>
                    </div>
                </div>

                <!-- 2. SEO Optimization -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <div class="flex items-start gap-6 mb-6">
                            <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center text-brand-400 shrink-0 group-hover:scale-110 transition-transform">
                                📈
                            </div>
                            <div>
                                <span class="text-xs font-bold text-brand-500/60 tracking-widest uppercase">02</span>
                                <h3 class="text-xl font-bold text-white mt-1">SEO Optimization</h3>
                            </div>
                        </div>
                        <p class="text-slate-400 mb-6 leading-relaxed">Rank higher and capture buyers before your competitors do. We coordinate search positioning blueprints across tech architecture, high-value local pages, and backlinking.</p>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Keyword research &amp; indexing audit</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> On-page content &amp; local landing pages</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Backlink building &amp; digital authority</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Continuous rank tracking &amp; optimization</li>
                        </ul>
                    </div>
                </div>

                <!-- 3. AI Search Optimization (AISO) -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <div class="flex items-start gap-6 mb-6">
                            <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center text-brand-400 shrink-0 group-hover:scale-110 transition-transform">
                                🤖
                            </div>
                            <div>
                                <span class="text-xs font-bold text-brand-500/60 tracking-widest uppercase">03</span>
                                <h3 class="text-xl font-bold text-white mt-1">AI Search Optimization</h3>
                            </div>
                        </div>
                        <p class="text-slate-400 mb-6 leading-relaxed">Get recommended by AI. We configure websites, citation references, and content structures so emerging AI platforms trust and refer your business.</p>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Optimization for ChatGPT, Claude &amp; Gemini</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Structured data &amp; schema injections</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Entity optimization &amp; knowledge graph alignment</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> AI citation &amp; trust authority building</li>
                        </ul>
                    </div>
                </div>

                <!-- 4. Google Business Profile & Maps -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <div class="flex items-start gap-6 mb-6">
                            <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center text-brand-400 shrink-0 group-hover:scale-110 transition-transform">
                                📍
                            </div>
                            <div>
                                <span class="text-xs font-bold text-brand-500/60 tracking-widest uppercase">04</span>
                                <h3 class="text-xl font-bold text-white mt-1">Google Business Profile</h3>
                            </div>
                        </div>
                        <p class="text-slate-400 mb-6 leading-relaxed">Maximize visibility inside local search and maps. We manage reviews, local ranking setups, posts, and details to capture users looking to buy nearby.</p>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Maps pack rankings improvements</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Profile audit &amp; description optimization</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Review acquisition &amp; monitoring strategy</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Photos &amp; GMB weekly posting support</li>
                        </ul>
                    </div>
                </div>

                <!-- 5. Website Maintenance & Support -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <div class="flex items-start gap-6 mb-6">
                            <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center text-brand-400 shrink-0 group-hover:scale-110 transition-transform">
                                🛡️
                            </div>
                            <div>
                                <span class="text-xs font-bold text-brand-500/60 tracking-widest uppercase">05</span>
                                <h3 class="text-xl font-bold text-white mt-1">Website Maintenance</h3>
                            </div>
                        </div>
                        <p class="text-slate-400 mb-6 leading-relaxed">Keep your website secure, fast, and stable round-the-clock. We handle technical audits, backups, and security threats so you can focus on operations.</p>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Daily backups &amp; recovery vaults</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> WordPress, plugins &amp; code software updates</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Cybersecurity monitoring &amp; malware sweeps</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Broken links fix &amp; code troubleshooting</li>
                        </ul>
                    </div>
                </div>

                <!-- 6. Google Ads & PPC Marketing -->
                <div class="group p-8 rounded-2xl bg-slate-900 border border-white/5 hover:border-brand-500/30 transition-all duration-300 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative z-10">
                        <div class="flex items-start gap-6 mb-6">
                            <div class="w-14 h-14 rounded-xl bg-slate-800 flex items-center justify-center text-brand-400 shrink-0 group-hover:scale-110 transition-transform">
                                ⚡
                            </div>
                            <div>
                                <span class="text-xs font-bold text-brand-500/60 tracking-widest uppercase">06</span>
                                <h3 class="text-xl font-bold text-white mt-1">Google Ads &amp; PPC Marketing</h3>
                            </div>
                        </div>
                        <p class="text-slate-400 mb-6 leading-relaxed">Drive immediate, high-quality targeted phone calls and form entries. We construct paid campaigns that optimize conversion values while lowering your CPA.</p>
                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Search ads &amp; PMax local campaign models</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Click-to-call campaign optimization</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Retargeting lists &amp; landing funnel builds</li>
                            <li class="flex items-center gap-3 text-sm text-slate-300"><span class="text-brand-400 font-bold">✓</span> Advanced conversion reporting parameters</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-24 bg-slate-900/50 relative overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[300px] bg-brand-600/10 blur-[150px] rounded-full pointer-events-none"></div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="text-center mb-16">
                <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-4">
                    Why Us
                </div>
                <h2 class="text-4xl md:text-5xl font-bold text-white">Why Brands Choose WebSolution</h2>
            </div>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="text-center p-8 rounded-2xl bg-slate-900 border border-white/5">
                    <div class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600 mb-3">98%</div>
                    <div class="text-lg font-bold text-white mb-3">Client Satisfaction</div>
                    <p class="text-slate-400 text-sm leading-relaxed">Our clients consistently rate us highly on project delivery, communication, and results.</p>
                </div>
                <div class="text-center p-8 rounded-2xl bg-slate-900 border border-white/5">
                    <div class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600 mb-3">3&times;</div>
                    <div class="text-lg font-bold text-white mb-3">Average Traffic Growth</div>
                    <p class="text-slate-400 text-sm leading-relaxed">Brands we build for see an average 3&times; increase in organic traffic within 6 months.</p>
                </div>
                <div class="text-center p-8 rounded-2xl bg-slate-900 border border-white/5">
                    <div class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600 mb-3">72h</div>
                    <div class="text-lg font-bold text-white mb-3">Average Response Time</div>
                    <p class="text-slate-400 text-sm leading-relaxed">From inquiry to project kickoff — we move fast and keep you in the loop at every step.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-24">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Let's Discuss Your Project</h2>
            <p class="text-slate-400 text-lg mb-10 max-w-lg mx-auto">Tell us what you need and we'll put together a tailored plan for your business.</p>
            <a href="tel:+18322667209" class="inline-flex items-center justify-center px-10 py-4 rounded-lg text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-1 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.8)] border border-brand-400/30">
                Start Growing My Business Today
            </a>
        </div>
    </section>
</Layout>
