---
import Layout from '../../layouts/Layout.astro';

const seoTitle = "Affordable Small Business Website Design Services | Website Designer Near Me | Websolution";
const seoDescription = "Looking for a website designer near me? Get a professional small business website with zero deposit, ready in 7 days, full dashboard access, hosting included, and affordable monthly pricing.";
const pageUrl = "https://websolutiontx.com/small-business-website-design-services/";
const siteName = "Websolution";

const faqItems = [
  {
    question: "How much does a small business website cost?",
    answer: "Websolution offers affordable website design services with simple monthly pricing. There is no large upfront deposit required. Your monthly plan includes professional website design, domain registration, hosting, SSL security, dashboard access, review management, lead generation tools, and ongoing maintenance. Contact us at (832) 266-7209 for a personalized quote based on your business needs."
  },
  {
    question: "Can I get a website without paying a deposit?",
    answer: "Yes. Websolution requires zero deposit to get started. We believe every small business deserves a professional online presence without the financial burden of a large upfront payment. You simply pay an affordable monthly fee that covers your entire online presence, including design, hosting, domain, SSL, maintenance, and support."
  },
  {
    question: "What is included in the website design service?",
    answer: "Every Websolution website package includes professional website design, domain name registration, web hosting, SSL security certificate, full dashboard access, review management platform, lead generation tools, inquiry management, Google Maps integration, social media integration, ongoing website maintenance, and dedicated technical support from our Houston-based team."
  },
  {
    question: "How quickly can my website be completed?",
    answer: "Most small business websites are designed, built, and launched within 7 business days. Our streamlined process ensures your business gets online fast without sacrificing quality. Larger or more complex projects may require additional time, which we will communicate clearly during the planning phase."
  },
  {
    question: "Will I have dashboard access to manage my website?",
    answer: "Absolutely. Every client receives full dashboard access to manage their website content, view analytics, track leads, manage reviews, and monitor inquiries. You maintain complete control over your online presence while our team handles the technical maintenance and updates."
  },
  {
    question: "Is hosting included with my website?",
    answer: "Yes, reliable web hosting is included in every Websolution monthly plan at no additional cost. We host your website on fast, secure servers optimized for performance and uptime. You never need to worry about purchasing or managing separate hosting services."
  },
  {
    question: "Can my website generate leads for my business?",
    answer: "Yes. Every website we build includes built-in lead generation tools such as contact forms, call-to-action buttons, click-to-call functionality, and inquiry management systems. These tools are designed to convert website visitors into real business leads, phone calls, and customer inquiries."
  },
  {
    question: "Will my website be mobile friendly?",
    answer: "Yes, every website designed by Websolution is fully mobile responsive. Your website will look and function perfectly on smartphones, tablets, laptops, and desktop computers. Mobile-friendly design is essential for user experience and Google search rankings, and we build it into every project from the start."
  },
  {
    question: "Can my website rank in Google search results?",
    answer: "Yes. Every website we build follows SEO best practices including proper heading structure, meta tags, fast page speed, mobile responsiveness, structured data markup, and clean URL architecture. We design your website to be search engine friendly so it has the best possible foundation for ranking in Google, Bing, and other search engines."
  },
  {
    question: "Can my website appear in AI search results like ChatGPT or Google AI Overviews?",
    answer: "Yes. Websolution builds websites with AI search optimization in mind. We implement structured data, schema markup, clear content architecture, and authority signals that help AI platforms like ChatGPT, Google AI Overviews, Gemini, Claude, Perplexity, and Microsoft Copilot understand, trust, and reference your business information."
  },
  {
    question: "Do I need SEO for my small business website?",
    answer: "SEO is essential for any business that wants to be found online. Without SEO, your website may not appear in search results when potential customers search for your services. Websolution builds every website with SEO-friendly structure, and we also offer dedicated SEO services to help your business rank higher and attract more organic traffic over time."
  },
  {
    question: "Why should I choose a Houston website design company?",
    answer: "Choosing a local Houston website design company like Websolution means you get personalized service from a team that understands the local market. We have been serving Houston and Texas businesses since 2014, providing responsive local support, understanding regional business needs, and building websites optimized for local search visibility. Our clients benefit from a long-term partnership with a team they can reach directly."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Websolution",
  "description": "Affordable small business website design services in Houston, Texas. Professional website design, SEO, and digital marketing agency serving Houston and Texas businesses since 2014.",
  "url": "https://websolutiontx.com",
  "telephone": "+18322667209",
  "email": "websolutiontx@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Houston",
    "addressRegion": "TX",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "29.7604",
    "longitude": "-95.3698"
  },
  "areaServed": [
    { "@type": "City", "name": "Houston" },
    { "@type": "State", "name": "Texas" }
  ],
  "foundingDate": "2014",
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "18:00"
  }
};

const professionalServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Websolution - Small Business Website Design",
  "description": "Professional small business website design services including domain, hosting, SSL, dashboard access, review management, and lead generation tools. Zero deposit required, website ready in 7 days.",
  "url": pageUrl,
  "provider": {
    "@type": "Organization",
    "name": "Websolution",
    "url": "https://websolutiontx.com"
  },
  "areaServed": [
    { "@type": "City", "name": "Houston" },
    { "@type": "State", "name": "Texas" }
  ],
  "serviceType": ["Website Design", "Web Development", "SEO", "Lead Generation", "Review Management"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://websolutiontx.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Small Business Website Design Services",
      "item": pageUrl
    }
  ]
};

const industries = [
  { name: "Medical Practices", icon: "🏥", desc: "HIPAA-aware website design for clinics, dental offices, and healthcare providers with patient inquiry forms and appointment scheduling." },
  { name: "Law Firms", icon: "⚖️", desc: "Professional attorney websites with case inquiry forms, practice area pages, and trust-building design that converts visitors into consultations." },
  { name: "Contractors", icon: "🔨", desc: "Lead-generating websites for general contractors, electricians, plumbers, and construction companies with project galleries and estimate requests." },
  { name: "Restaurants", icon: "🍽️", desc: "Appetizing restaurant websites with menu displays, online ordering integration, reservation links, and Google Maps location visibility." },
  { name: "Retail Businesses", icon: "🛍️", desc: "Engaging retail websites that showcase products, drive foot traffic, and integrate with your point-of-sale and inventory systems." },
  { name: "Professional Services", icon: "💼", desc: "Authority-building websites for consultants, accountants, financial advisors, and professional service firms with lead capture tools." },
  { name: "Home Service Companies", icon: "🏠", desc: "High-converting websites for HVAC, roofing, landscaping, cleaning, and home service businesses with service area pages and booking forms." }
];

const whyChooseItems = [
  { title: "Professional Website Design Built for Growth", desc: "Modern, conversion-focused website design that positions your business for long-term success and customer acquisition.", icon: "rocket" },
  { title: "Zero Upfront Deposit Required", desc: "Start your professional website with no deposit. Simple, affordable monthly pricing makes professional web design accessible for every small business.", icon: "wallet" },
  { title: "Website Ready in 7 Days", desc: "Our streamlined design process gets your business online fast. Most websites are designed, built, and launched within 7 business days.", icon: "clock" },
  { title: "Domain Name, Hosting & SSL Included", desc: "Everything you need is included — domain registration, reliable web hosting, and SSL security certificate — all at no extra cost.", icon: "shield" },
  { title: "Full Dashboard Access", desc: "Manage your content, track analytics, monitor leads, and control your online presence through an intuitive dashboard built for business owners.", icon: "dashboard" },
  { title: "Review Management Platform Included", desc: "Monitor and respond to customer reviews across platforms. Build your online reputation and trust with a built-in review management system.", icon: "star" },
  { title: "Lead Generation Tools Included", desc: "Every website includes contact forms, call-to-action buttons, click-to-call, and inquiry tracking to convert visitors into paying customers.", icon: "magnet" },
  { title: "Mobile Friendly Design", desc: "Responsive design that looks and performs flawlessly on smartphones, tablets, and desktops — optimized for how your customers browse today.", icon: "mobile" },
  { title: "SEO Friendly Website Structure", desc: "Built with clean code, semantic HTML, proper heading structure, fast loading speed, and structured data to help your business rank in search engines.", icon: "search" },
  { title: "Houston Based Team Since 2014", desc: "Work with a local Houston team that understands your market. Personalized service, responsive support, and a long-term growth partnership.", icon: "location" },
  { title: "Built for Google Search, AI Search & Voice Search", desc: "Your website is optimized for traditional search engines, AI platforms like ChatGPT and Gemini, Google AI Overviews, and voice search assistants.", icon: "ai" }
];
---

<Layout title={seoTitle} description={seoDescription}>
  <Fragment slot="head">
    <!-- Open Graph -->
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <main>
    <!-- ============================================ -->
    <!-- SECTION 1: HERO                              -->
    <!-- ============================================ -->
    <section class="relative min-h-[100vh] flex items-center pt-24 pb-20 overflow-hidden bg-black" id="hero">
      <!-- Background gradient effects -->
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-black to-slate-950"></div>
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-600/8 blur-[200px] rounded-full pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-brand-500/5 blur-[150px] rounded-full pointer-events-none"></div>
      </div>

      <!-- Subtle grid pattern overlay -->
      <div class="absolute inset-0 z-0 opacity-[0.03]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-5xl mx-auto text-center">
          <!-- Trust badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-8">
            <span class="w-2 h-2 rounded-full bg-brand-400 animate-pulse"></span>
            Serving Houston & Texas Businesses Since 2014
          </div>

          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-[1.1] mb-6 tracking-tight">
            Affordable <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">Small Business Website Design</span> in Houston
          </h1>

          <p class="text-lg md:text-xl text-slate-300 mb-4 max-w-3xl mx-auto leading-relaxed">
            Looking for a <strong class="text-white">website designer near me</strong>? Get a professional website, domain, hosting, dashboard access, review management, and lead generation tools included.
          </p>

          <p class="text-base text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed">
            Professional small business website design services with zero deposit, affordable monthly pricing, and your website ready in 7 days. Everything your business needs to succeed online.
          </p>

          <!-- Benefits Grid -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-3xl mx-auto mb-12">
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">Zero Deposit</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">Ready in 7 Days</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">Domain Included</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">Hosting Included</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">SSL Included</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">Dashboard Access</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">Review Management</span>
            </div>
            <div class="flex items-center gap-2 px-3 py-2.5 rounded-xl bg-white/5 border border-white/5 backdrop-blur-sm">
              <span class="text-brand-400 text-sm font-bold">✓</span>
              <span class="text-slate-300 text-xs sm:text-sm font-medium">Lead Gen Tools</span>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/contact" id="hero-cta-primary" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-10 py-4 rounded-xl text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-0.5 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.7)] border border-brand-400/30">
              Get My Website Started Today
            </a>
            <a href="tel:+18322667209" id="hero-cta-phone" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 rounded-xl text-base font-semibold text-white border border-white/10 bg-white/5 hover:bg-white/10 transition-all duration-300 backdrop-blur-sm">
              <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              Call (832) 266-7209
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom gradient fade -->
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-slate-950 to-transparent z-10 pointer-events-none"></div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 2: WHY BUSINESSES CHOOSE WEBSOLUTION -->
    <!-- ============================================ -->
    <section class="py-24 lg:py-32 bg-slate-950 relative overflow-hidden" id="why-choose">
      <div class="absolute top-1/2 left-0 -translate-x-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-brand-600/5 blur-[150px] rounded-full pointer-events-none"></div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-6">
            Why Businesses Choose Us
          </div>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">Why Houston Businesses Choose Websolution for Website Design</h2>
          <p class="text-lg text-slate-400 leading-relaxed">
            Everything you need for a professional online presence — included in one affordable monthly plan. No hidden fees, no surprise charges, no long-term contracts.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {whyChooseItems.map((item, i) => (
            <div class={`group p-7 rounded-2xl border transition-all duration-300 hover:-translate-y-1 relative overflow-hidden ${i === 0 ? 'bg-gradient-to-br from-brand-500/10 to-slate-900 border-brand-500/20 hover:border-brand-500/40 sm:col-span-2 lg:col-span-1' : 'bg-slate-900 border-white/5 hover:border-brand-500/30'}`}>
              <div class="absolute inset-0 bg-gradient-to-br from-brand-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="relative z-10">
                <div class="w-12 h-12 rounded-xl bg-slate-800 flex items-center justify-center mb-5 text-brand-400 group-hover:scale-110 transition-transform">
                  {item.icon === "rocket" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"></path></svg>}
                  {item.icon === "wallet" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"></path></svg>}
                  {item.icon === "clock" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>}
                  {item.icon === "shield" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path></svg>}
                  {item.icon === "dashboard" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"></path></svg>}
                  {item.icon === "star" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"></path></svg>}
                  {item.icon === "magnet" && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"></path></svg>}
