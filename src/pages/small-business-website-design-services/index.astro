                <span class="shrink-0 w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center text-brand-400 transition-transform" x-bind:class={`{ 'rotate-45': openFaq === ${index} }`}>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                </span>
              </button>
              <div
                x-show={`openFaq === ${index}`}
                x-transition:enter="transition ease-out duration-200"
                x-transition:enter-start="opacity-0 -translate-y-2"
                x-transition:enter-end="opacity-100 translate-y-0"
                x-transition:leave="transition ease-in duration-150"
                x-transition:leave-start="opacity-100 translate-y-0"
                x-transition:leave-end="opacity-0 -translate-y-2"
                class="px-6 pb-6"
                style="display: none;"
              >
                <p class="text-slate-400 text-sm leading-relaxed">{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 10: FINAL CTA                        -->
    <!-- ============================================ -->
    <section class="py-24 lg:py-32 bg-slate-950 relative overflow-hidden" id="final-cta">
      <div class="absolute inset-0">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] bg-brand-600/8 blur-[250px] rounded-full pointer-events-none"></div>
      </div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-3xl mx-auto">
          <div class="bg-slate-900 border border-white/5 rounded-3xl p-10 md:p-16 relative overflow-hidden text-center">
            <!-- Decorative glow -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-brand-500/10 blur-[100px] rounded-full pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 w-48 h-48 bg-brand-600/5 blur-[80px] rounded-full pointer-events-none"></div>

            <div class="relative z-10">
              <div class="inline-block px-4 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-sm font-medium mb-8">
                Get Started Today
              </div>

              <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">Ready to Launch Your Professional Website?</h2>

              <p class="text-lg text-slate-400 mb-10 leading-relaxed max-w-xl mx-auto">
                Join hundreds of Houston businesses that trust Websolution for affordable, professional website design. Everything you need — included.
              </p>

              <!-- Checklist -->
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-12 max-w-lg mx-auto text-left">
                {[
                  "Website Design",
                  "Domain Name",
                  "Hosting",
                  "SSL Security",
                  "Dashboard Access",
                  "Review Management",
                  "Lead Gen Tools",
                  "Maintenance",
                  "Local Support"
                ].map((item) => (
                  <div class="flex items-center gap-2">
                    <span class="text-brand-400 text-sm font-bold">✓</span>
                    <span class="text-slate-300 text-xs sm:text-sm font-medium">{item}</span>
                  </div>
                ))}
              </div>

              <!-- CTAs -->
              <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="/contact" id="final-cta-primary" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-10 py-4 rounded-xl text-base font-bold text-white bg-gradient-to-r from-brand-500 to-brand-600 hover:opacity-90 hover:-translate-y-0.5 transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(219,107,39,0.7)] border border-brand-400/30">
                  Get My Website Started Today
                </a>
                <a href="tel:+18322667209" id="final-cta-phone" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 rounded-xl text-base font-semibold text-white border border-white/10 bg-white/5 hover:bg-white/10 transition-all duration-300 backdrop-blur-sm">
                  <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                  Call (832) 266-7209
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Breadcrumb (visually minimal, SEO beneficial) -->
